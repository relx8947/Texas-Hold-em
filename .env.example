# 后端监听地址
ADDR=:8080
# SQLite 数据文件路径
DATA_PATH=/data/data.db
# 前端静态文件目录
STATIC_DIR=/app/web
# 允许的 WebSocket Origin，多个用逗号分隔；设置后将严格校验
ALLOWED_ORIGINS=http://localhost:8080
# 单条 WebSocket 消息大小上限（字节）
WS_READ_LIMIT_BYTES=4096
# WebSocket 写超时（秒）
WS_WRITE_TIMEOUT_SECONDS=10
# WebSocket Pong 超时（秒）
WS_PONG_TIMEOUT_SECONDS=60
# WebSocket Ping 间隔（秒）
WS_PING_INTERVAL_SECONDS=25
# 玩家行动超时自动弃牌（秒）
ACTION_TIMEOUT_SECONDS=30
# 断线保留座位的超时（分钟）
DISCONNECT_TIMEOUT_MINUTES=5
# 一手牌结算后自动开始下一手的延迟（秒），设为 0 立即开始
NEXT_HAND_DELAY_SECONDS=6
